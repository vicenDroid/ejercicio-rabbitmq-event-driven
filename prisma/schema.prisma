generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Order {
  id        String   @id @default(uuid())
  status    String
  createdAt DateTime @default(now())
}

model OutboxEvent {
  id        String   @id @default(uuid())
  payload   Json
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}